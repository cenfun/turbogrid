{
    "name": "turbogrid",
    "version": "3.2.3",
    "description": "A high-performance JavaScript data grid library with zero dependencies",
    "main": "dist/turbogrid.js",
    "module": "dist/turbogrid.esm.js",
    "exports": {
        ".": {
            "import": "./dist/turbogrid.esm.js",
            "require": "./dist/turbogrid.js",
            "default": "./dist/turbogrid.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "dev": "sf dev",
        "test": "sf test",
        "lint": "sf lint",
        "build": "sf lint && sf b -e -p patch",
        "patch": "npm run build && sf publish patch",
        "pack": "sf pack -o docs"
    },
    "files": [
        "dist",
        "README.zh-Hans.md"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cenfun/turbogrid.git"
    },
    "dependencies": {},
    "devDependencies": {
        "eslint": "^10.1.0",
        "eslint-config-plus": "^2.0.4",
        "eslint-plugin-html": "^8.1.4",
        "stylelint": "^17.5.0",
        "stylelint-config-plus": "^1.1.5",
        "vine-ui": "^3.1.18"
    }
}