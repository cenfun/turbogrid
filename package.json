{
    "name": "turbogrid",
    "version": "3.3.1",
    "description": "A high-performance JavaScript data grid library with zero dependencies",
    "type": "module",
    "main": "dist/turbogrid.js",
    "module": "dist/turbogrid.esm.js",
    "exports": {
        ".": {
            "types": "./dist/turbogrid.d.ts",
            "import": "./dist/turbogrid.esm.js",
            "require": "./dist/turbogrid.js",
            "default": "./dist/turbogrid.js"
        },
        "./package.json": "./package.json"
    },
    "types": "dist/turbogrid.d.ts",
    "scripts": {
        "dev": "vite",
        "test": "sf test",
        "lint": "eslint src/ && stylelint src/**/*.scss",
        "build": "npm run lint && vite build",
        "patch": "npm run build && sf publish patch",
        "pack": "sf pack -o docs"
    },
    "files": [
        "dist",
        "README.zh-Hans.md"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cenfun/turbogrid.git"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^6.0.7",
        "eslint": "^10.4.1",
        "eslint-config-plus": "^2.0.4",
        "eslint-plugin-vue": "^10.9.2",
        "prismjs": "^1.30.0",
        "sass": "^1.100.0",
        "stylelint": "^17.13.0",
        "stylelint-config-plus": "^1.1.6",
        "vine-ui": "^3.1.18",
        "vite": "^8.0.16",
        "vue": "^3.5.35",
        "vue-eslint-parser": "^10.4.1",
        "vue-router": "^5.1.0"
    }
}